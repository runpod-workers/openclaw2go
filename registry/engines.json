{
  "a2go-llamacpp": {
    "id": "a2go-llamacpp",
    "name": "a2go-llamacpp (unified fork)",
    "description": "Unified llama.cpp fork merging main + audio/TTS, GLM-5 DSA, OuteTTS 1.0, Eagle-3",
    "binary": "/opt/engines/a2go-llamacpp/bin/llama-server",
    "binaryTts": "/opt/engines/a2go-llamacpp/bin/llama-tts",
    "binaryAudio": "/opt/engines/a2go-llamacpp/bin/llama-liquid-audio-server",
    "libPath": "/opt/engines/a2go-llamacpp/lib",
    "type": "native",
    "source": "https://github.com/runpod-labs/a2go-llamacpp"
  },
  "image-gen": {
    "id": "image-gen",
    "name": "Image Generation (Diffusers + SDNQ)",
    "binary": "/usr/local/bin/a2go-image-server",
    "venvPath": "/opt/engines/pytorch/venv",
    "type": "python-venv"
  },
  "qwen3-tts": {
    "id": "qwen3-tts",
    "name": "Qwen3-TTS (PyTorch)",
    "binary": "/usr/local/bin/a2go-tts-server",
    "venvPath": "/opt/engines/pytorch/venv",
    "type": "python-venv"
  },
  "mlx-lm": {
    "id": "mlx-lm",
    "name": "MLX LM (Mac)",
    "binary": "python -m mlx_lm.server",
    "type": "python-venv"
  },
  "mlx-audio": {
    "id": "mlx-audio",
    "name": "MLX Audio (Mac)",
    "binary": "python -m mlx_audio.server",
    "type": "python-venv"
  },
  "mflux": {
    "id": "mflux",
    "name": "mflux Image Gen (Mac)",
    "binary": "~/.a2go/bin/mflux-server",
    "type": "python-venv"
  },
  "a2go-media": {
    "id": "a2go-media",
    "name": "Unified Media Server (FastAPI)",
    "binary": "/usr/local/bin/a2go-media-server",
    "venvPath": "/opt/engines/pytorch/venv",
    "type": "python-venv"
  }
}
