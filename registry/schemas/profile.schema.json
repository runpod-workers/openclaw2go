{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "agent2go Profile Config",
  "description": "Schema for profile (preset) configuration files in the a2go-registry",
  "type": "object",
  "required": ["id", "name", "services"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique profile ID"
    },
    "name": {
      "type": "string",
      "description": "Human-readable profile name"
    },
    "gpu": {
      "type": "string",
      "description": "Target GPU ID from the GPU registry"
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["model", "role", "port"],
        "properties": {
          "model": {
            "type": "string",
            "description": "Model ID to use for this service"
          },
          "role": {
            "type": "string",
            "enum": ["llm", "audio", "image"],
            "description": "Service role"
          },
          "port": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
          },
          "overrides": {
            "type": "object",
            "description": "Override settings for this service"
          }
        }
      }
    },
    "webProxy": {
      "type": "boolean",
      "description": "Whether to enable the web proxy"
    },
    "vramTotal": {
      "type": "integer",
      "minimum": 0,
      "description": "Estimated total VRAM usage in MB"
    },
    "status": {
      "type": "string",
      "enum": ["stable", "experimental", "deprecated"]
    }
  },
  "additionalProperties": false
}
