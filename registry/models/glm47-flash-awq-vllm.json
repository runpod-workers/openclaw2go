{
  "id": "cyankiwi/glm47-flash-awq-4bit",
  "name": "GLM-4.7-Flash AWQ 4-bit (vLLM)",
  "type": "llm",
  "engine": "vllm",
  "repo": "cyankiwi/GLM-4.7-Flash-AWQ-4bit",
  "downloadMode": "repo",
  "downloadDir": "/workspace/models/GLM-4.7-Flash-AWQ-4bit",
  "servedAs": "glm-4.7-flash",
  "vram": { "model": 17300, "overhead": 1500 },
  "defaults": { "contextLength": 114688, "port": 8000 },
  "startDefaults": { "gpuMemoryUtilization": "0.92" },
  "extraStartArgs": [
    "--trust-remote-code",
    "--enable-auto-tool-choice", "--tool-call-parser", "glm47",
    "--reasoning-parser", "glm45",
    "--block-size", "32",
    "--enable-prefix-caching",
    "--max-num-batched-tokens", "8192"
  ],
  "provider": { "name": "local-vllm", "api": "openai-completions" },
  "default": false,
  "status": "stable"
}
