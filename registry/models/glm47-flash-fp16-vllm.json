{
  "id": "zai-org/glm47-flash-fp16",
  "name": "GLM-4.7-Flash FP16 (vLLM)",
  "type": "llm",
  "engine": "vllm",
  "repo": "zai-org/GLM-4.7-Flash",
  "downloadMode": "repo",
  "downloadDir": "/workspace/models/GLM-4.7-Flash-FP16",
  "servedAs": "glm-4.7-flash",
  "vram": { "model": 31000, "overhead": 2000 },
  "defaults": { "contextLength": 65536, "port": 8000 },
  "startDefaults": { "gpuMemoryUtilization": "0.92" },
  "extraStartArgs": [
    "--trust-remote-code",
    "--enable-auto-tool-choice", "--tool-call-parser", "glm47",
    "--reasoning-parser", "glm45",
    "--block-size", "32",
    "--enable-prefix-caching"
  ],
  "provider": { "name": "local-vllm", "api": "openai-completions" },
  "default": false,
  "status": "stable"
}
