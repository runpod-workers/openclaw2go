# Dockerfile.unified - Unified agent2go image
#
# Uses pre-built llama.cpp binaries from the engines image (no compilation).
# Build the engines image first: see engines/Dockerfile and engines-build.yml.
#
# Multi-stage build:
#   Stage 1 (build-pytorch): Build shared PyTorch venv (image-gen + Qwen3-TTS) in devel image
#   Stage 2 (runtime):       Slim runtime with only pre-built artifacts
#
# Configuration at runtime via A2GO_CONFIG env var:
#   {"llm": "unsloth/GLM-4.7-Flash-GGUF", "audio": "LiquidAI/LFM2.5-Audio-1.5B-GGUF", "image": "Disty0/FLUX.2-klein-4B-SDNQ-4bit-dynamic"}
#   {"llm": "unsloth/GLM-4.7-Flash-GGUF", "audio": "LiquidAI/LFM2.5-Audio-1.5B-GGUF"}
#   {"llm": "unsloth/GLM-4.7-Flash-GGUF", "contextLength": 200000}
#   {"profile": "rtx5090-full-stack"}                              — use a preset
#
# Model names are case-insensitive. Use HuggingFace repo names or short IDs.
#
# Build: docker build -f Dockerfile.unified -t a2go .

ARG ENGINES_IMAGE=runpod/a2go-engines:latest
ARG CUDA_VERSION=12.8
ARG UBUNTU_VERSION=24.04

# Pull pre-built engines (llama.cpp LLM + Audio binaries)
FROM ${ENGINES_IMAGE} AS engines

# ============================================================
# Stage 1: Build shared PyTorch venv (image-gen + Qwen3-TTS)
# ============================================================
FROM nvcr.io/nvidia/cuda-dl-base:25.03-cuda${CUDA_VERSION}-devel-ubuntu${UBUNTU_VERSION} AS build-pytorch

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-dev python3-venv python3-pip \
    && rm -f /usr/lib/python*/EXTERNALLY-MANAGED \
    && rm -rf /var/lib/apt/lists/*

# Shared PyTorch venv for a2go-media-server (image-gen + Qwen3-TTS + LFM2-Audio)
# PyTorch cu128 required for RTX 5090 (Blackwell sm_120), works on all others too
# Diffusers from git required for Flux2KleinPipeline
# qwen-tts + soundfile for Qwen3-TTS, liquid-audio for LFM2.5-Audio
# flash-attn for performance (optional)
# fastapi + uvicorn for the unified media server
RUN python3 -m venv /opt/engines/pytorch/venv && \
    /opt/engines/pytorch/venv/bin/pip install --no-cache-dir \
        torch torchaudio --index-url https://download.pytorch.org/whl/cu128 && \
    /opt/engines/pytorch/venv/bin/pip install --no-cache-dir \
        sdnq git+https://github.com/huggingface/diffusers.git \
        transformers accelerate safetensors \
        qwen-tts liquid-audio soundfile \
        fastapi "uvicorn[standard]" httpx python-multipart && \
    /opt/engines/pytorch/venv/bin/pip install --no-cache-dir \
        flash-attn --no-build-isolation || true && \
    find /opt/engines/pytorch/venv -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null; \
    find /opt/engines/pytorch/venv -type f -name "*.pyc" -delete 2>/dev/null; \
    rm -rf /opt/engines/pytorch/venv/lib/python*/site-packages/torch/test \
           /opt/engines/pytorch/venv/lib/python*/site-packages/torch/include \
           /opt/engines/pytorch/venv/lib/python*/site-packages/torch/share \
           /opt/engines/pytorch/venv/lib/python*/site-packages/caffe2 \
    ; true

# ============================================================
# Stage 2: Slim runtime image
# ============================================================
FROM nvidia/cuda:${CUDA_VERSION}.1-runtime-ubuntu${UBUNTU_VERSION}

ARG CUDA_VERSION
ENV DEBIAN_FRONTEND=noninteractive

# Runtime-only system dependencies (no build tools)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl git libgomp1 \
    python3 python3-pip \
    openssh-server \
    && rm -f /etc/ssh/ssh_host_* && mkdir -p /var/run/sshd \
    && rm -f /usr/lib/python*/EXTERNALLY-MANAGED \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# ── Engine: a2go-llamacpp ──────────────────────────────
# Unified fork: LLM, Audio, Vision, Embeddings, TTS, GLM-5 DSA, Eagle-3
COPY --from=engines /opt/engines/a2go-llamacpp/ /opt/engines/a2go-llamacpp/
RUN ldconfig /opt/engines/a2go-llamacpp/lib/

# ── Engine: shared PyTorch venv (image-gen + Qwen3-TTS, from Stage 1) ──
COPY --from=build-pytorch /opt/engines/pytorch/venv/ /opt/engines/pytorch/venv/

# ── Node.js + GitHub CLI ──────────────────────────────────
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | \
    dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg && \
    chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
    > /etc/apt/sources.list.d/github-cli.list && \
    apt-get update && apt-get install -y --no-install-recommends nodejs gh && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# ── Python tools ──────────────────────────────────────────
RUN python3 -m pip install --no-cache-dir huggingface_hub

# ── OpenClaw + Claude Code ────────────────────────────────
ARG OPENCLAW_VERSION=latest
RUN npm install -g --prefer-offline --omit=dev @anthropic-ai/claude-code openclaw@${OPENCLAW_VERSION} wandler@latest && \
    npm cache clean --force

# ── Hermes Agent ──────────────────────────────────────────
ARG HERMES_TAG=main
RUN curl -fsSL https://raw.githubusercontent.com/NousResearch/hermes-agent/main/scripts/install.sh | bash -s -- --branch ${HERMES_TAG} || true
ENV PATH="/root/.local/bin:${PATH}"

WORKDIR /

# ── Environment defaults ──────────────────────────────────
ENV A2GO_API_KEY="changeme" \
    A2GO_AUTH_TOKEN="changeme" \
    A2GO_STATE_DIR="" \
    A2GO_WORKSPACE="" \
    A2GO_REGISTRY_DIR="/opt/a2go/registry" \
    A2GO_REGISTRY_OFFLINE="" \
    A2GO_REGISTRY_TTL_SECONDS="3600"

# ── Copy application files ────────────────────────────────
COPY registry/ /opt/a2go/registry/
COPY registry/templates/ /opt/a2go/templates/
COPY config/workspace/skills/ /opt/a2go/skills/
COPY web/ /opt/a2go/web/
COPY plugins/ /opt/a2go/plugins/
COPY config/ /opt/a2go/config/
COPY scripts/entrypoint-common.sh /opt/a2go/entrypoint-common.sh
COPY scripts/entrypoint-unified.sh /opt/a2go/entrypoint-unified.sh
COPY scripts/resolve-profile.py /opt/a2go/scripts/resolve-profile.py
COPY scripts/vram-budget.py /opt/a2go/scripts/vram-budget.py
# ── a2go CLI (Go binary) ─────────────────────────────────
ARG A2GO_CLI_VERSION=latest
RUN ARCH=$(uname -m) && \
    [ "$ARCH" = "aarch64" ] && ARCH="arm64" || ARCH="amd64" && \
    if [ "$A2GO_CLI_VERSION" = "latest" ]; then \
      URL=$(curl -fsSL -o /dev/null -w '%{redirect_url}' https://github.com/runpod-labs/a2go/releases/latest/download/a2go_linux_${ARCH} 2>/dev/null || true) && \
      [ -n "$URL" ] && curl -fsSL -o /usr/local/bin/a2go "$URL" || \
      curl -fsSL -o /usr/local/bin/a2go "https://github.com/runpod-labs/a2go/releases/latest/download/a2go_linux_${ARCH}"; \
    else \
      curl -fsSL -o /usr/local/bin/a2go "https://github.com/runpod-labs/a2go/releases/download/${A2GO_CLI_VERSION}/a2go_linux_${ARCH}"; \
    fi && \
    chmod +x /usr/local/bin/a2go

COPY scripts/a2go-profiles /usr/local/bin/a2go-profiles
COPY scripts/a2go-registry /usr/local/bin/a2go-registry
COPY scripts/a2go-image-server /usr/local/bin/a2go-image-server
COPY scripts/a2go-tts-server /usr/local/bin/a2go-tts-server
COPY scripts/a2go-media-server /usr/local/bin/a2go-media-server
COPY scripts/media_plugins/ /usr/local/lib/media_plugins/
RUN chmod +x /opt/a2go/entrypoint-unified.sh \
    /opt/a2go/scripts/resolve-profile.py \
    /opt/a2go/scripts/vram-budget.py \
    /usr/local/bin/a2go-profiles \
    /usr/local/bin/a2go-registry \
    /usr/local/bin/a2go-image-server \
    /usr/local/bin/a2go-tts-server \
    /usr/local/bin/a2go-media-server

EXPOSE 8000 8080 18789 8642 22
ENTRYPOINT ["/opt/a2go/entrypoint-unified.sh"]
