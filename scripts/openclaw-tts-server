#!/usr/bin/env python3
"""
openclaw-tts-server - Qwen3-TTS speech synthesis server
OpenAI-compatible /v1/audio/speech endpoint

Keeps model loaded in VRAM for instant inference.
Starts on port 8006, accepts POST requests with JSON body.
"""

import argparse
import io
import json
import os
import sys
import time
import struct
from http.server import HTTPServer, BaseHTTPRequestHandler

# Reduce VRAM pressure from torch.compile/inductor
os.environ.setdefault("TORCH_COMPILE_DISABLE", "1")
os.environ.setdefault("TORCHDYNAMO_DISABLE", "1")
os.environ.setdefault("TORCHINDUCTOR_DISABLE", "1")
os.environ.setdefault("PYTORCH_CUDA_ALLOC_CONF", "expandable_segments:True")

# Global model reference
tts_model = None
device = None
server_port = 8006

AUDIO_OUTPUT_DIR = os.environ.get("OPENCLAW_AUDIO_OUTPUT_DIR", "/workspace/openclaw/audio")

# Default voice mapping (OpenAI-compatible voice names → Qwen3-TTS speaker names)
# Qwen3-TTS CustomVoice speakers: aiden, dylan, eric, ono_anna, ryan, serena, sohee, uncle_fu, vivian
VOICE_MAP = {
    "alloy": "vivian",
    "echo": "eric",
    "fable": "serena",
    "onyx": "ryan",
    "nova": "aiden",
    "shimmer": "sohee",
}

DEFAULT_SAMPLE_RATE = 24000


def ensure_output_dir():
    os.makedirs(AUDIO_OUTPUT_DIR, exist_ok=True)


def build_wav_header(pcm_data_len, sample_rate=DEFAULT_SAMPLE_RATE, channels=1, bits_per_sample=16):
    """Build a WAV file header for raw PCM data."""
    byte_rate = sample_rate * channels * bits_per_sample // 8
    block_align = channels * bits_per_sample // 8
    header = struct.pack(
        "<4sI4s4sIHHIIHH4sI",
        b"RIFF",
        36 + pcm_data_len,
        b"WAVE",
        b"fmt ",
        16,
        1,  # PCM
        channels,
        sample_rate,
        byte_rate,
        block_align,
        bits_per_sample,
        b"data",
        pcm_data_len,
    )
    return header


class TTSHandler(BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        print(f"[TTSServer] {args[0]}")

    def do_GET(self):
        if self.path == "/health":
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.end_headers()
            self.wfile.write(json.dumps({
                "status": "ok",
                "model_loaded": tts_model is not None,
            }).encode())
        else:
            self.send_response(404)
            self.end_headers()

    def do_POST(self):
        if self.path != "/v1/audio/speech":
            self.send_response(404)
            self.send_header("Content-Type", "application/json")
            self.end_headers()
            self.wfile.write(json.dumps({"error": f"unknown endpoint: {self.path}"}).encode())
            return

        try:
            content_length = int(self.headers.get("Content-Length", 0))
            body = self.rfile.read(content_length)
            data = json.loads(body)

            text = data.get("input", "")
            if not text:
                self.send_response(400)
                self.send_header("Content-Type", "application/json")
                self.end_headers()
                self.wfile.write(json.dumps({"error": "input text required"}).encode())
                return

            voice = data.get("voice", "alloy")
            response_format = data.get("response_format", "wav")
            speed = data.get("speed", 1.0)

            # Map OpenAI voice name to speaker description
            speaker_desc = VOICE_MAP.get(voice, voice)

            print(f"[TTSServer] Synthesizing ({voice}): {text[:80]}...")
            t0 = time.time()

            audio_data = synthesize(text, speaker_desc, speed)

            elapsed = time.time() - t0
            print(f"[TTSServer] Done in {elapsed:.2f}s, {len(audio_data)} bytes")

            if response_format == "wav":
                content_type = "audio/wav"
            elif response_format == "mp3":
                content_type = "audio/mpeg"
            elif response_format == "opus":
                content_type = "audio/opus"
            elif response_format == "flac":
                content_type = "audio/flac"
            else:
                content_type = "audio/wav"

            self.send_response(200)
            self.send_header("Content-Type", content_type)
            self.send_header("Content-Length", str(len(audio_data)))
            self.end_headers()
            self.wfile.write(audio_data)

        except Exception as e:
            import traceback
            print(f"[TTSServer] Error: {e}")
            traceback.print_exc()
            self.send_response(500)
            self.send_header("Content-Type", "application/json")
            self.end_headers()
            self.wfile.write(json.dumps({"error": str(e)}).encode())


def synthesize(text, speaker, speed=1.0):
    """Synthesize speech using Qwen3-TTS CustomVoice and return WAV bytes."""
    import soundfile as sf
    import numpy as np

    # generate_custom_voice returns (List[np.ndarray], sample_rate)
    audio_arrays, sample_rate = tts_model.generate_custom_voice(
        text=text,
        speaker=speaker,
    )

    # Concatenate all audio segments
    if len(audio_arrays) > 1:
        audio_array = np.concatenate(audio_arrays)
    else:
        audio_array = audio_arrays[0]

    audio_array = audio_array.squeeze()

    # Write to WAV buffer
    buf = io.BytesIO()
    sf.write(buf, audio_array, sample_rate, format="WAV", subtype="PCM_16")
    return buf.getvalue()


def load_model(model_dir):
    """Load the Qwen3-TTS model."""
    global tts_model, device
    import torch

    print(f"[TTSServer] Loading Qwen3-TTS from: {model_dir}")
    device = "cuda" if torch.cuda.is_available() else "cpu"
    dtype = torch.bfloat16 if device == "cuda" else torch.float32

    from qwen_tts import Qwen3TTSModel

    kwargs = {}
    if device == "cuda":
        kwargs["device_map"] = "cuda:0"
        kwargs["dtype"] = dtype

    tts_model = Qwen3TTSModel.from_pretrained(model_dir, **kwargs)

    print(f"[TTSServer] Model loaded on {device}")

    if device == "cuda":
        allocated = torch.cuda.memory_allocated() / 1024**3
        print(f"[TTSServer] VRAM allocated: {allocated:.2f} GB")


def main():
    global server_port
    parser = argparse.ArgumentParser(description="Qwen3-TTS speech synthesis server")
    parser.add_argument("--model-dir", required=True, help="Path to model directory")
    parser.add_argument("--host", default="0.0.0.0", help="Bind host")
    parser.add_argument("--port", type=int, default=8006, help="Bind port")
    args = parser.parse_args()
    server_port = args.port

    ensure_output_dir()
    load_model(args.model_dir)

    server = HTTPServer((args.host, args.port), TTSHandler)
    print(f"[TTSServer] Listening on http://{args.host}:{args.port}")
    print("[TTSServer] POST /v1/audio/speech with JSON: {input, voice, response_format, speed}")
    server.serve_forever()


if __name__ == "__main__":
    main()
