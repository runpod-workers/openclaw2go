#!/usr/bin/env python3
"""
mflux-server - Persistent FLUX image generation server for Apple Silicon (MLX)
Keeps model loaded in unified memory for instant inference

Starts on port 8002, accepts POST requests with JSON body.
Same API as openclaw-image-server so a2go tool image-generate works unchanged.
"""

import argparse
import base64
import io
import json
import math
import os
import sys
import time
from http.server import HTTPServer, BaseHTTPRequestHandler
from pathlib import Path


def _patch_transformers_local_path():
    """Work around transformers >= 5.x rejecting local paths as repo IDs.

    transformers 5.x validates every path_or_repo_id against HuggingFace repo ID
    rules, even when it's a local filesystem path.  This breaks mflux's tokenizer
    loading which passes local cache paths to from_pretrained().

    The fix: wrap cached_files() so that a real local directory is turned into a
    pathlib.Path *before* the validator sees it.  transformers already has a
    fast-path for Path objects that skips the repo-ID check.
    """
    try:
        import transformers.utils.hub as _hub

        _original = _hub.cached_files

        def _patched(path_or_repo_id, *a, **kw):
            if isinstance(path_or_repo_id, str) and os.path.isdir(path_or_repo_id):
                path_or_repo_id = Path(path_or_repo_id)
            return _original(path_or_repo_id, *a, **kw)

        _hub.cached_files = _patched
    except Exception:
        pass  # older transformers — patch not needed


_patch_transformers_local_path()

# Global model reference
flux = None
last_image_path = None
server_port = 8002
model_name = None

IMAGE_OUTPUT_DIR = os.environ.get(
    "A2GO_IMAGE_OUTPUT_DIR",
    os.path.expanduser("~/.a2go/images"),
)


def ensure_output_dir():
    os.makedirs(IMAGE_OUTPUT_DIR, exist_ok=True)


def safe_basename(name):
    return os.path.basename(name)


def build_image_name(seed, width, height):
    ts = int(time.time())
    return f"openclaw-{ts}-{seed}-{width}x{height}.png"


def round_to_multiple(value, multiple=8):
    return int(math.ceil(value / multiple) * multiple)


def parse_aspect(aspect):
    if ":" in aspect:
        parts = aspect.split(":")
    elif "x" in aspect:
        parts = aspect.split("x")
    else:
        raise ValueError("Aspect ratio must be like 1:1 or 16:9.")
    w = float(parts[0])
    h = float(parts[1])
    if w <= 0 or h <= 0:
        raise ValueError("Aspect ratio values must be positive.")
    return w / h


def resolve_size(width, height, aspect, long_side=1024):
    if width and height:
        w = width
        h = height
    elif aspect:
        ratio = parse_aspect(aspect)
        if ratio >= 1:
            w = long_side
            h = long_side / ratio
        else:
            h = long_side
            w = long_side * ratio
    else:
        w = long_side
        h = long_side
    w = round_to_multiple(max(256, int(w)))
    h = round_to_multiple(max(256, int(h)))
    return w, h


class ImageHandler(BaseHTTPRequestHandler):
    def log_message(self, format, *args):
        print(f"[mflux-server] {args[0]}")

    def do_GET(self):
        if self.path == "/health":
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.end_headers()
            self.wfile.write(json.dumps({
                "status": "ok",
                "model_loaded": flux is not None,
            }).encode())
        elif self.path == "/latest":
            if last_image_path:
                self._serve_file(last_image_path)
            else:
                self.send_response(404)
                self.end_headers()
        elif self.path.startswith("/images/"):
            image_name = safe_basename(self.path[len("/images/"):])
            image_path = os.path.join(IMAGE_OUTPUT_DIR, image_name)
            self._serve_file(image_path)
        else:
            self.send_response(404)
            self.end_headers()

    def _serve_file(self, path):
        real_root = os.path.realpath(IMAGE_OUTPUT_DIR)
        real_path = os.path.realpath(path)
        if not real_path.startswith(real_root + os.sep) and real_path != real_root:
            self.send_response(403)
            self.end_headers()
            return
        if not os.path.isfile(real_path):
            self.send_response(404)
            self.end_headers()
            return
        try:
            with open(real_path, "rb") as f:
                data = f.read()
            content_type = (
                "image/png" if real_path.lower().endswith(".png")
                else "application/octet-stream"
            )
            self.send_response(200)
            self.send_header("Content-Type", content_type)
            self.send_header("Content-Length", str(len(data)))
            self.end_headers()
            self.wfile.write(data)
        except Exception:
            self.send_response(500)
            self.end_headers()

    def do_POST(self):
        if self.path != "/generate":
            self.send_response(404)
            self.end_headers()
            return

        try:
            content_length = int(self.headers.get("Content-Length", 0))
            body = self.rfile.read(content_length)
            data = json.loads(body)

            prompt = data.get("prompt", "")
            if not prompt:
                self.send_response(400)
                self.send_header("Content-Type", "application/json")
                self.end_headers()
                self.wfile.write(json.dumps({"error": "prompt required"}).encode())
                return

            width = data.get("width")
            height = data.get("height")
            aspect = data.get("aspect")
            long_side = data.get("long_side", 1024)
            steps = data.get("steps", 4)
            guidance = data.get("guidance", 1.0)
            seed = data.get("seed", 0)

            w, h = resolve_size(width, height, aspect, long_side)
            print(f"[mflux-server] Generating {w}x{h}: {prompt[:50]}...")

            result = flux.generate_image(
                seed=seed,
                prompt=prompt,
                width=w,
                height=h,
                num_inference_steps=steps,
                guidance=guidance,
            )

            # GeneratedImage has an .image attribute (PIL Image)
            image = result.image if hasattr(result, 'image') else result
            img_buffer = io.BytesIO()
            image.save(img_buffer, format="PNG")
            img_bytes = img_buffer.getvalue()

            ensure_output_dir()
            filename = data.get("filename") or data.get("name")
            if filename:
                filename = safe_basename(filename)
            else:
                filename = build_image_name(seed, w, h)
            image_path = os.path.join(IMAGE_OUTPUT_DIR, filename)
            with open(image_path, "wb") as f:
                f.write(img_bytes)
            global last_image_path
            last_image_path = image_path

            image_url = f"/images/{filename}"
            local_url = f"http://localhost:{server_port}{image_url}"

            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.end_headers()
            self.wfile.write(json.dumps({
                "image": base64.b64encode(img_bytes).decode(),
                "width": w,
                "height": h,
                "format": "png",
                "image_name": filename,
                "image_path": image_path,
                "image_url": image_url,
                "image_local_url": local_url,
                "image_proxy_url": None,
                "image_public_url": None,
            }).encode())
            print(f"[mflux-server] Done, {len(img_bytes)} bytes")

        except Exception as e:
            import traceback
            print(f"[mflux-server] Error: {e}")
            traceback.print_exc()
            self.send_response(500)
            self.send_header("Content-Type", "application/json")
            self.end_headers()
            self.wfile.write(json.dumps({"error": str(e)}).encode())


def _enable_vae_tiling(tile_size=(512, 512)):
    """Monkey-patch Flux2VAE to use tiled decoding, reducing peak memory ~50%.

    The standard VAE decodes the full latent at once, using ~9.6 GB for 1024x1024.
    Tiled decoding processes 512x512 tiles with cosine-blended overlap, dropping
    overhead to ~2.8 GB with no visible quality loss.
    """
    import mlx.core as mx
    from mflux.models.flux2.model.flux2_vae.vae import Flux2VAE
    from mflux.models.common.vae.vae_tiler import VAETiler

    _original_decode = Flux2VAE.decode_packed_latents

    def decode_packed_latents_tiled(self, packed_latents):
        if packed_latents.ndim == 5:
            packed_latents = packed_latents[:, :, 0, :, :]
        bn_mean = self.bn.running_mean.reshape(1, -1, 1, 1)
        bn_std = mx.sqrt(self.bn.running_var.reshape(1, -1, 1, 1) + self.bn.eps)
        latents = packed_latents * bn_std + bn_mean
        latents = Flux2VAE._unpatchify_latents(latents)
        # Wrap to 5D [B, C, 1, H, W] for VAETiler
        latent_5d = latents[:, :, None, :, :]

        def decode_fn(tile):
            return self.decode(tile)[:, :, None, :, :]

        decoded = VAETiler.decode_image_tiled(
            latent=latent_5d,
            decode_fn=decode_fn,
            tile_size=tile_size,
            tile_overlap=(64, 64),
            spatial_scale=8,
        )
        return decoded

    Flux2VAE.decode_packed_latents = decode_packed_latents_tiled
    print(f"[mflux-server] VAE tiling enabled ({tile_size[0]}x{tile_size[1]} tiles)")


def load_model(model_id, quantize):
    global flux, model_name
    model_name = model_id

    print(f"[mflux-server] Loading model: {model_id} (quantize={quantize})")

    from mflux.models.common.resolution.config_resolution import ConfigResolution

    model_config = ConfigResolution.resolve(model_id)
    resolved_name = model_config.model_name if hasattr(model_config, "model_name") else ""

    # FLUX.2 Klein models need the Flux2Klein class, FLUX.1 models use Flux1
    is_flux2 = "klein" in model_id.lower() or "klein" in resolved_name.lower() or "FLUX.2" in resolved_name
    if is_flux2:
        from mflux.models.flux2.variants.txt2img.flux2_klein import Flux2Klein

        # Enable tiled VAE decode to reduce peak memory (~50% reduction at 1024x1024)
        _enable_vae_tiling()

        flux = Flux2Klein(quantize=quantize, model_config=model_config)
        print(f"[mflux-server] Loaded as Flux2Klein: {resolved_name}")
    else:
        from mflux.models.flux.variants.txt2img.flux import Flux1
        flux = Flux1(quantize=quantize, model_config=model_config)
        print(f"[mflux-server] Loaded as Flux1: {resolved_name}")

    print(f"[mflux-server] Model loaded in unified memory")


def main():
    global server_port
    parser = argparse.ArgumentParser(
        description="FLUX image generation server for Apple Silicon (mflux)"
    )
    parser.add_argument(
        "--model",
        default="mlx-community/FLUX.1-schnell-4bit-quantized",
        help="HuggingFace model ID or mflux model alias",
    )
    parser.add_argument("--host", default="0.0.0.0", help="Bind host")
    parser.add_argument("--port", type=int, default=8002, help="Bind port")
    parser.add_argument(
        "--quantize", type=int, default=4, choices=[4, 8],
        help="Quantization bits (4 or 8)",
    )
    args = parser.parse_args()
    server_port = args.port

    ensure_output_dir()
    load_model(args.model, args.quantize)

    server = HTTPServer((args.host, args.port), ImageHandler)
    print(f"[mflux-server] Listening on http://{args.host}:{args.port}")
    print("[mflux-server] POST /generate with JSON: {prompt, width, height, aspect, steps, guidance, seed}")
    server.serve_forever()


if __name__ == "__main__":
    main()
