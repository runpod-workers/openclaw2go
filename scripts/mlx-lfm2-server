#!/usr/bin/env python3
"""
MLX LFM2.5-Audio server — TTS and STT via mlx_audio.sts.

Workaround for mlx-audio's get_model_category() not supporting the STS
category where LFM2.5 lives. Loads the model directly and exposes
OpenAI-compatible endpoints.
"""

import argparse
import io
import time

import mlx.core as mx
import numpy as np
import soundfile as sf
import uvicorn
from fastapi import FastAPI, File, Form, Request, UploadFile
from fastapi.responses import JSONResponse, Response

VOICE_MAP = {
    "alloy": "US female",
    "echo": "US male",
    "fable": "UK female",
    "onyx": "UK male",
    "nova": "US female",
    "shimmer": "UK female",
}

app = FastAPI(title="a2go LFM2.5-Audio (MLX)")
_model = None
_processor = None


def load_model(model_id: str):
    global _model, _processor
    from mlx_audio.sts.models.lfm_audio import LFM2AudioModel, LFM2AudioProcessor

    print(f"[LFM2-MLX] Loading model: {model_id}")
    t0 = time.time()
    _processor = LFM2AudioProcessor.from_pretrained(model_id)
    _model = LFM2AudioModel.from_pretrained(model_id)
    mx.eval(_model.parameters())
    elapsed = time.time() - t0
    print(f"[LFM2-MLX] Model loaded in {elapsed:.1f}s")


@app.get("/health")
async def health():
    return {"status": "ok", "model_loaded": _model is not None}


@app.get("/v1/models")
async def models():
    return {"object": "list", "data": [{"id": "lfm2.5-audio", "object": "model"}] if _model else []}


@app.post("/v1/audio/speech")
async def tts(request: Request):
    from mlx_audio.sts.models.lfm_audio import ChatState, LFMModality
    from mlx_audio.sts.models.lfm_audio.model import AUDIO_EOS_TOKEN

    data = await request.json()
    text = data.get("input", "")
    if not text:
        return JSONResponse(status_code=400, content={"error": "input text required"})

    voice = data.get("voice", "echo")
    voice_desc = VOICE_MAP.get(voice, voice)

    print(f"[LFM2-MLX] TTS ({voice_desc}): {text[:80]}...")
    t0 = time.time()

    chat = ChatState(_processor)
    chat.new_turn("system")
    chat.add_text(f"Perform TTS. Use the {voice_desc} voice.")
    chat.end_turn()
    chat.new_turn("user")
    chat.add_text(text)
    chat.end_turn()
    chat.new_turn("assistant")

    audio_codes = []
    for token, modality in _model.generate_sequential(
        **dict(chat), max_new_tokens=2048, audio_temperature=0.8, audio_top_k=64,
    ):
        mx.eval(token)
        if modality == LFMModality.AUDIO_OUT:
            if token[0].item() == AUDIO_EOS_TOKEN:
                break
            audio_codes.append(token)

    if not audio_codes:
        return JSONResponse(status_code=500, content={"error": "No audio generated"})

    codes = mx.stack(audio_codes, axis=0)[None, :].transpose(0, 2, 1)
    waveform = _processor.decode_audio(codes)
    audio_np = np.array(waveform[0], dtype=np.float32)

    buf = io.BytesIO()
    sf.write(buf, audio_np, _model.sample_rate, format="WAV", subtype="PCM_16")
    wav_bytes = buf.getvalue()

    elapsed = time.time() - t0
    print(f"[LFM2-MLX] TTS done in {elapsed:.2f}s, {len(wav_bytes)} bytes")

    return Response(content=wav_bytes, media_type="audio/wav")


@app.post("/v1/audio/transcriptions")
async def stt(file: UploadFile = File(...), model: str = Form("")):
    from mlx_audio.sts.models.lfm_audio import ChatState, LFMModality

    audio_bytes = await file.read()
    print(f"[LFM2-MLX] STT: {file.filename or 'upload'} ({len(audio_bytes)} bytes)")
    t0 = time.time()

    buf = io.BytesIO(audio_bytes)
    wav_np, sr = sf.read(buf, dtype="float32")
    audio = mx.array(wav_np)

    chat = ChatState(_processor)
    chat.new_turn("user")
    chat.add_audio(audio, sample_rate=sr)
    chat.add_text("Transcribe the audio.")
    chat.end_turn()
    chat.new_turn("assistant")

    text_parts = []
    for token, modality in _model.generate_interleaved(
        **dict(chat), max_new_tokens=512,
    ):
        mx.eval(token)
        if modality == LFMModality.TEXT:
            text_parts.append(_processor.decode_text(token[None]))

    text = "".join(text_parts).strip()
    elapsed = time.time() - t0
    print(f"[LFM2-MLX] STT done in {elapsed:.2f}s: {text[:100]}...")

    return JSONResponse(content={"text": text})


def main():
    parser = argparse.ArgumentParser(description="LFM2.5-Audio MLX server")
    parser.add_argument("--model", required=True, help="HuggingFace model ID")
    parser.add_argument("--host", default="0.0.0.0")
    parser.add_argument("--port", type=int, default=8001)
    args = parser.parse_args()

    load_model(args.model)
    uvicorn.run(app, host=args.host, port=args.port, log_level="info")


if __name__ == "__main__":
    main()
